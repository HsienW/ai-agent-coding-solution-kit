{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/prompt-engineering/structured-artifact-generation/input.schema.json",
  "title": "Offer Card Artifact Generation Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "artifactType",
    "locale",
    "requirements"
  ],
  "properties": {
    "taskId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "artifactType": {
      "const": "offer_card"
    },
    "locale": {
      "type": "string",
      "enum": [
        "en",
        "zh-TW"
      ]
    },
    "requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "states",
        "fields"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "maxLength": 500
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "maxLength": 64
          }
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
          }
        },
        "actionOverrides": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 64
          }
        }
      }
    },
    "designTokens": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    },
    "apiFields": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
      }
    },
    "untrustedContext": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "maxLength": 2000
      }
    }
  }
}
