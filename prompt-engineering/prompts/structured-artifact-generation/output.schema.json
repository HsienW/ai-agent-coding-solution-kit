{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/prompt-engineering/structured-artifact-generation/output.schema.json",
  "title": "Offer Card Artifact Specification",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "artifactType",
    "locale",
    "title",
    "fields",
    "states",
    "diagnostics"
  ],
  "properties": {
    "specVersion": {
      "const": "1.0.0"
    },
    "artifactType": {
      "const": "offer_card"
    },
    "locale": {
      "type": "string",
      "enum": [
        "en",
        "zh-TW"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9_]*$"
      }
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label",
          "action",
          "appearance"
        ],
        "properties": {
          "id": {
            "type": "string",
            "enum": [
              "available",
              "activated",
              "expired"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "action": {
            "type": "string",
            "enum": [
              "activate_now",
              "activated",
              "disabled"
            ]
          },
          "appearance": {
            "type": "string",
            "enum": [
              "default",
              "success",
              "muted",
              "warning"
            ]
          }
        }
      }
    },
    "designTokens": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean"
        ]
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domainValidated",
        "warnings"
      ],
      "properties": {
        "domainValidated": {
          "type": "boolean"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    }
  }
}
